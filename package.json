{
  "name": "crosmos-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Crosmos Memory Engine",
  "main": "dist/index.js",
  "bin": {
    "crosmos-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "@biomejs/biome": "^1.9.0"
  }
}
