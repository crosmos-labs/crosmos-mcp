# Crosmos Memory Engine API Configuration
CROSMOS_API_BASE_URL=http://localhost:8000
CROSMOS_API_TIMEOUT=30000

# API Key for authentication (required for user-scoped access)
# Generate your key at the Crosmos dashboard and paste it here
CROSMOS_API_KEY=csk_your_api_key_here

# Default memory space ID (optional)
DEFAULT_SPACE_ID=1
